# ==========================================================
# Scryve Backend - Environment Configuration (example)
# Copy this file to `.env` and fill in real values.
# ==========================================================

# --- Application ---
APP_NAME=Scryve
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1

# --- Database (PostgreSQL) ---
POSTGRES_USER=scryve
POSTGRES_PASSWORD=scryve123
POSTGRES_DB=scryve
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Optional: full DSN overrides the discrete fields above.
# DATABASE_URL=postgresql+psycopg2://scryve:scryve@localhost:5432/scryve

# --- Security / JWT ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
# Comma-separated list of allowed origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Logging ---
LOG_LEVEL=INFO

# --- Embeddings (Phase 3 — Job Intelligence) ---
# Backend selection: "hashing" (default, dependency-free, deterministic)
# or "sentence-transformers" (requires the optional package to be installed).
EMBEDDING_BACKEND=hashing
EMBEDDING_MODEL_NAME=hashing-v1
EMBEDDING_DIMENSION=384
